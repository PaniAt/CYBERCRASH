;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CYBERCRASH"
config/description="CYBERCRASH"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

CameraController="*res://camera_controller.gd"
Math="*res://math.gd"
ScreenTransition="*res://Interfaces/screen_transition.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://08lkccj71rmr"

[global_group]

Players="This group should be reserved only for the player and nothing else."

